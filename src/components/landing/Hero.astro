---
import warehouseImg from "../../assets/warehouse.jpg";
---

<section class="hero">
  <div
    class="hero-bg"
    style={`background-image: url(${warehouseImg.src})`}
    aria-hidden="true"
  ></div>

  <div class="hero-content">
    <div class="tracking-card">
      <!-- Package icon -->
      <div class="card-title">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16.5 9.4 7.55 4.24"/>
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 2 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          <polyline points="3.29 7 12 12 20.71 7"/>
          <line x1="12" y1="22" x2="12" y2="12"/>
        </svg>
        <h1>
          <span class="zh">追踪您的货物</span>
          <span class="en">Track Your Shipment</span>
        </h1>
      </div>

      <p class="card-subtitle">
        <span class="zh">输入运单号以查询状态</span>
        <span class="en">Enter your tracking number to check status</span>
      </p>

      <form class="tracking-form" action="/tracking" method="get">
        <input
          type="text"
          name="id"
          class="tracking-input"
          placeholder-zh="输入运单号"
          placeholder-en="Enter Tracking Number"
          autocomplete="off"
          aria-label="Tracking number"
        />
        <button type="submit" class="track-btn">
          <span class="zh">查询</span>
          <span class="en">Track</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  // Sync input placeholder with active language
  function syncPlaceholders() {
    const lang = document.documentElement.getAttribute("data-lang") ?? "en";
    document.querySelectorAll<HTMLInputElement>("[placeholder-zh]").forEach((el) => {
      el.placeholder = lang === "zh"
        ? (el.getAttribute("placeholder-zh") ?? "")
        : (el.getAttribute("placeholder-en") ?? "");
    });
  }

  syncPlaceholders();

  // Re-sync when language changes (MutationObserver on <html>)
  const observer = new MutationObserver(syncPlaceholders);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ["data-lang"] });
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 340px;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 60%;
    background-repeat: no-repeat;
    /* subtle dark overlay for contrast */
    filter: brightness(0.88);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 52px 24px;
  }

  /* Tracking card */
  .tracking-card {
    background: #FFF8F0;
    border-radius: 12px;
    padding: 28px 28px 32px;
    max-width: 380px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.28), 0 2px 8px rgba(0, 0, 0, 0.12);
  }

  .card-title {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #1A1A1A;
    margin-bottom: 8px;
  }

  .card-title svg {
    flex-shrink: 0;
    color: #E16D28;
  }

  .card-title h1 {
    font-size: 20px;
    font-weight: 800;
    margin: 0;
    line-height: 1.3;
  }

  .card-subtitle {
    font-size: 13px;
    color: #7A7A7A;
    margin: 0 0 16px 32px;
    line-height: 1.5;
  }

  .tracking-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-left: 32px;
  }

  .tracking-input {
    width: 100%;
    padding: 10px 14px;
    border: 2.5px solid #bbb;
    border-radius: 6px;
    font-size: 14px;
    color: #1A1A1A;
    background: #fff;
    outline: none;
    transition: border-color 0.2s;
  }

  .tracking-input:focus {
    border-color: #E16D28;
  }

  .tracking-input::placeholder {
    color: #b0b0b0;
  }

  .track-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    background: #E16D28;
    color: #fff;
    border: none;
    border-radius: 24px;
    padding: 10px 22px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .track-btn:hover {
    background: #C95E20;
  }

  @media (max-width: 480px) {
    .tracking-card {
      max-width: 100%;
    }
  }
</style>
