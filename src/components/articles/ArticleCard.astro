---
interface Props {
  slug: string;
  title: string;
  titleZh: string;
  date: Date;
  excerpt: string;
  excerptZh: string;
  heroImage?: string;
  tags?: string[];
  tagsZh?: string[];
  variant?: "featured" | "list";
}

const {
  slug,
  title,
  titleZh,
  date,
  excerpt,
  excerptZh,
  heroImage,
  tags = [],
  tagsZh = [],
  variant = "list",
} = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
const formattedDateZh = date.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

{variant === "featured" ? (
  <!-- Featured card — image LEFT, content RIGHT -->
  <a href={`/articles/${slug}`} class="card-featured">
    {heroImage && (
      <div class="featured-img-wrap">
        <img src={heroImage} alt={title} class="featured-img" loading="lazy" />
      </div>
    )}
    <div class="featured-body">
      <span class="featured-badge">
        <span class="zh">精选</span>
        <span class="en">FEATURED</span>
      </span>
      <h3 class="featured-title">
        <span class="zh">{titleZh}</span>
        <span class="en">{title}</span>
      </h3>
      <p class="featured-excerpt">
        <span class="zh">{excerptZh}</span>
        <span class="en">{excerpt}</span>
      </p>
      <span class="read-more">
        <span class="zh">阅读更多</span>
        <span class="en">READ MORE</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </span>
    </div>
  </a>
) : (
  <!-- List row: date | tags+title+excerpt | READ MORE -->
  <a href={`/articles/${slug}`} class="card-list"
    data-search={[title, titleZh, ...tags, ...tagsZh].join(" ").toLowerCase()}
  >
    <div class="list-date">
      <span class="zh">{formattedDateZh}</span>
      <span class="en">{formattedDate}</span>
    </div>
    <div class="list-body">
      <!-- Tags above title -->
      {(tags.length > 0 || tagsZh.length > 0) && (
        <div class="list-tags">
          <span class="zh">
            {tagsZh.map((tag) => <span class="tag">#{tag}</span>)}
          </span>
          <span class="en">
            {tags.map((tag) => <span class="tag">#{tag}</span>)}
          </span>
        </div>
      )}
      <h3 class="list-title">
        <span class="zh">{titleZh}</span>
        <span class="en">{title}</span>
      </h3>
      <p class="list-excerpt">
        <span class="zh">{excerptZh}</span>
        <span class="en">{excerpt}</span>
      </p>
    </div>
    <span class="read-more list-read-more">
      <span class="zh">阅读</span>
      <span class="en">READ MORE</span>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </span>
  </a>
)}

<style>
  /* ── Featured — image left, content right ─────────────── */
  .card-featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    text-decoration: none;
    color: inherit;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #eee;
    transition: box-shadow 0.2s;
    height: 100%;
  }

  .card-featured:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.1);
  }

  .featured-img-wrap {
    width: 100%;
    height: 100%;
    min-height: 220px;
    overflow: hidden;
  }

  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card-featured:hover .featured-img {
    transform: scale(1.04);
  }

  .featured-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .featured-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #E16D28;
  }

  .featured-title {
    font-size: 18px;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0;
    line-height: 1.35;
  }

  .featured-excerpt {
    font-size: 13px;
    color: #4A4A4A;
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }

  /* ── List row ─────────────────────────────────────────── */
  .card-list {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    align-items: start;
    gap: 16px;
    padding: 20px 0;
    border-bottom: 1px solid #eee;
    text-decoration: none;
    color: inherit;
  }

  .card-list:last-child {
    border-bottom: none;
  }

  .card-list:hover .list-title {
    color: #E16D28;
  }

  .list-date {
    font-size: 12px;
    color: #7A7A7A;
    font-weight: 500;
    padding-top: 2px;
    line-height: 1.4;
  }

  /* Tags above title */
  .list-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 6px;
  }

  .tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: #4A4A4A;
    background: #F0F0F0;
    border-radius: 20px;
    padding: 2px 10px;
  }

  .list-title {
    font-size: 15px;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 6px;
    line-height: 1.35;
    transition: color 0.15s;
  }

  .list-excerpt {
    font-size: 13px;
    color: #4A4A4A;
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Shared ───────────────────────────────────────────── */
  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #E16D28;
    white-space: nowrap;
  }

  .list-read-more {
    flex-shrink: 0;
    align-self: center;
  }

  @media (max-width: 600px) {
    .card-featured {
      grid-template-columns: 1fr;
    }

    .featured-img-wrap {
      min-height: 180px;
      height: 180px;
    }
  }
</style>
