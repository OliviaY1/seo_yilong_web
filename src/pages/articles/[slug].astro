---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { title, titleZh, date, heroImage, tags, tagsZh } = article.data;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const formattedDateZh = date.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} — Yilong`}>
  <div class="article-page">
    <div class="article-inner">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">
          <span class="zh">首页</span>
          <span class="en">Home</span>
        </a>
        <span class="sep">›</span>
        <a href="/articles">
          <span class="zh">文章</span>
          <span class="en">Articles</span>
        </a>
        <span class="sep">›</span>
        <span class="current">
          <span class="zh">{titleZh}</span>
          <span class="en">{title}</span>
        </span>
      </nav>

      <!-- Title -->
      <h1 class="article-title">
        <span class="zh">{titleZh}</span>
        <span class="en">{title}</span>
      </h1>

      <!-- Date -->
      <p class="article-date">
        <span class="zh">{formattedDateZh}</span>
        <span class="en">{formattedDate}</span>
      </p>

      <!-- Hero image -->
      {heroImage && (
        <div class="hero-img-wrap">
          <img src={heroImage} alt={title} class="hero-img" />
        </div>
      )}

      <!-- Markdown content -->
      <div class="article-body">
        <Content />
      </div>

      <!-- Tags -->
      {(tags.length > 0 || tagsZh.length > 0) && (
        <div class="article-tags">
          <span class="zh">
            {tagsZh.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </span>
          <span class="en">
            {tags.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </span>
        </div>
      )}

      <!-- Back link -->
      <a href="/articles" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        <span class="zh">返回文章列表</span>
        <span class="en">Back to Articles</span>
      </a>

    </div>
  </div>
</Layout>

<style>
  .article-page {
    background: #fff;
    padding: 40px 24px 80px;
  }

  .article-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #7A7A7A;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    text-decoration: none;
    color: #7A7A7A;
    transition: color 0.15s;
  }

  .breadcrumb a:hover { color: #E16D28; }
  .breadcrumb .sep { color: #bbb; }
  .breadcrumb .current { color: #4A4A4A; }

  /* Title */
  .article-title {
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 800;
    color: #1A1A1A;
    line-height: 1.2;
    margin: 0 0 12px;
  }

  /* Date */
  .article-date {
    font-size: 13px;
    color: #7A7A7A;
    margin: 0 0 28px;
  }

  /* Hero image */
  .hero-img-wrap {
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 40px;
    aspect-ratio: 16 / 7;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Markdown body */
  .article-body {
    color: #1A1A1A;
    font-size: 16px;
    line-height: 1.8;
  }

  .article-body :global(h2) {
    font-size: 22px;
    font-weight: 700;
    margin: 2em 0 0.6em;
    color: #1A1A1A;
  }

  .article-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    margin: 1.6em 0 0.5em;
    color: #1A1A1A;
  }

  .article-body :global(p) {
    margin: 0 0 1.2em;
    color: #2A2A2A;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.5em;
    margin: 0 0 1.2em;
  }

  .article-body :global(li) {
    margin-bottom: 0.4em;
    color: #2A2A2A;
  }

  .article-body :global(strong) {
    font-weight: 700;
    color: #1A1A1A;
  }

  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.4em 0;
    font-size: 14px;
  }

  .article-body :global(th),
  .article-body :global(td) {
    border: 1px solid #e0e0e0;
    padding: 8px 14px;
    text-align: left;
  }

  .article-body :global(th) {
    background: #f5f5f5;
    font-weight: 600;
  }

  .article-body :global(blockquote) {
    border-left: 4px solid #E16D28;
    margin: 1.4em 0;
    padding: 8px 16px;
    background: #FFF1E2;
    border-radius: 0 6px 6px 0;
    color: #4A4A4A;
  }

  /* Hide HTML comments rendered by Markdown */
  .article-body :global(p:empty) { display: none; }

  /* Tags */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid #eee;
  }

  .tag {
    display: inline-block;
    background: #F2F2F2;
    color: #4A4A4A;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    transition: background 0.15s, color 0.15s;
  }

  .tag:hover {
    background: #FFF1E2;
    color: #E16D28;
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 32px;
    font-size: 13px;
    font-weight: 600;
    color: #7A7A7A;
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover { color: #E16D28; }
</style>
